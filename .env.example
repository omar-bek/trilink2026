# =============================================================================
# PRODUCTION DEPLOYMENT CHECKLIST — read before going live
# =============================================================================
# [ ] APP_ENV=production
# [ ] APP_DEBUG=false                ← leaking stack traces = credential leaks
# [ ] APP_KEY set (php artisan key:generate --force)
# [ ] SESSION_ENCRYPT=true
# [ ] SESSION_SECURE_COOKIE=true
# [ ] LOG_LEVEL=warning               (debug logs fill disks + leak PII)
# [ ] DB_PASSWORD, JWT_SECRET, STRIPE_*, PAYPAL_* — all set, rotated quarterly
# [ ] QUEUE_CONNECTION=redis          (database queue doesn't scale past 1 worker)
# [ ] CACHE_STORE=redis
# [ ] SENTRY_LARAVEL_DSN set          (no observability = no incidents found)
# [ ] php artisan config:cache route:cache view:cache event:cache
# =============================================================================

APP_NAME="Tri Procurement Platform"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=Trilink
DB_USERNAME=
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=false

# Production overrides:
# SESSION_ENCRYPT=true
# SESSION_SECURE_COOKIE=true

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# Production overrides (use Redis):
# QUEUE_CONNECTION=redis
# CACHE_STORE=redis

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

JWT_SECRET=
JWT_TTL=21600
JWT_REFRESH_TTL=20160

FRONTEND_URL=http://localhost:3000

# Stripe
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# PayPal
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# Security
SECURITY_HEADERS_ENABLED=true
SECURITY_CSP=
SECURITY_ADMIN_IP_ALLOWLIST=

# WhatsApp
WHATSAPP_NUMBER=

# Observability (required in production)
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# Sanctum — set to the exact host(s) serving the SPA, no wildcards in prod.
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000
